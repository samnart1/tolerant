{
  "dashboard": {
    "title": "Microservices Fault-Tolerance Overview",
    "tags": ["thesis", "microservices", "resilience"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Request Rate (req/s)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count[5m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Error Rate (%)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (service) / sum(rate(http_server_requests_seconds_count[5m])) by (service) * 100",
            "legendFormat": "{{service}} errors"
          }
        ]
      },
      {
        "title": "P95 Latency (ms)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (service, le)) * 1000",
            "legendFormat": "{{service}} p95"
          }
        ]
      },
      {
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "resilience4j_circuitbreaker_state",
            "legendFormat": "{{name}} - {{state}}"
          }
        ]
      },
      {
        "title": "Order Success vs Failure",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(order_success_total[5m])",
            "legendFormat": "Success"
          },
          {
            "expr": "rate(order_failure_total[5m])",
            "legendFormat": "Failure"
          }
        ]
      },
      {
        "title": "Inventory Operations",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(inventory_check_success_total[5m])",
            "legendFormat": "Check Success"
          },
          {
            "expr": "rate(inventory_reserve_success_total[5m])",
            "legendFormat": "Reserve Success"
          },
          {
            "expr": "rate(inventory_check_failure_total[5m])",
            "legendFormat": "Check Failure"
          }
        ]
      },
      {
        "title": "Payment Processing",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(payment_success_total[5m])",
            "legendFormat": "Success"
          },
          {
            "expr": "rate(payment_failure_total[5m])",
            "legendFormat": "Failure"
          },
          {
            "expr": "rate(payment_retries_total[5m])",
            "legendFormat": "Retries"
          }
        ]
      },
      {
        "title": "CPU Usage by Service",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\".*-service-.*\"}[5m])) by (pod)",
            "legendFormat": "{{pod}}"
          }
        ]
      },
      {
        "title": "Memory Usage by Service",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{pod=~\".*-service-.*\"}) by (pod) / 1024 / 1024",
            "legendFormat": "{{pod}} (MB)"
          }
        ]
      },
      {
        "title": "Active Connections",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "sum(hikaricp_connections_active) by (pool)",
            "legendFormat": "{{pool}} active"
          }
        ]
      }
    ],
    "refresh": "5s",
    "schemaVersion": 27,
    "version": 1
  }
}