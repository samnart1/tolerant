# Experiment: Baseline + Failures
# No circuit breaker, WITH failures - shows cascading failure problem

CIRCUIT_BREAKER_ENABLED=false
CB_FAIL_MAX=5
CB_RESET_TIMEOUT=30

# Inject 30% failure rate on payment service
PAYMENT_FAILURE_RATE=30
PAYMENT_LATENCY_MS=0
PRODUCTCATALOG_FAILURE_RATE=0
PRODUCTCATALOG_LATENCY_MS=0
SHIPPING_FAILURE_RATE=0
SHIPPING_LATENCY_MS=0
CART_FAILURE_RATE=0
CART_LATENCY_MS=0
CHECKOUT_FAILURE_RATE=0
CHECKOUT_LATENCY_MS=0
RECOMMENDATION_FAILURE_RATE=0
RECOMMENDATION_LATENCY_MS=0
CURRENCY_FAILURE_RATE=0
CURRENCY_LATENCY_MS=0
