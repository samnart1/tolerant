# Experiment: Circuit Breaker + Failures
# Circuit breaker enabled, WITH failures - shows protection working

CIRCUIT_BREAKER_ENABLED=true
CB_FAIL_MAX=5
CB_RESET_TIMEOUT=30

# Same 30% failure rate on payment service
PAYMENT_FAILURE_RATE=30
