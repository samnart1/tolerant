PRODUCTCATALOG_FAILURE_RATE=0
PRODUCTCATALOG_LATENCY_MS=0
SHIPPING_FAILURE_RATE=0
SHIPPING_LATENCY_MS=0
CART_FAILURE_RATE=0
CART_LATENCY_MS=0
CHECKOUT_FAILURE_RATE=0
CHECKOUT_LATENCY_MS=0
RECOMMENDATION_FAILURE_RATE=0
RECOMMENDATION_LATENCY_MS=0
CURRENCY_FAILURE_RATE=0
CURRENCY_LATENCY_MS=0
